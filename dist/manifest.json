{
  "manifest_version": 3,
  "name": "bilibili视频文稿助手",
  "version": "1.1.0",
  "default_locale": "zh_CN",
  "icons": {
    "128": "icon.svg"
  },
  "description": "将bilibili视频逐字稿显示在您的网页中，支持AI转换字幕为文章，以便于快速浏览内容，或是复习记录与回顾。",
  "permissions": [
    "webRequest",
    "activeTab",
    "tabs",
    "webNavigation",
    "scripting",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/video/*",
        "https://www.bilibili.com/list/watchlater*"
      ],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}